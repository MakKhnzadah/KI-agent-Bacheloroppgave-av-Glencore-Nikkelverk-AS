@startuml

' Sequence Diagrams — AI Agent + Process Knowledge Base (Current Implementation)

skinparam style strictuml
skinparam shadowing false

title Seq 1: Search Knowledge (Vector Search)

actor Employee
participant "FastAPI API" as API
participant "Ollama Embeddings" as Embeddings
participant "Chroma Vector Store" as Chroma

Employee -> API : GET /vector/search?q=...
activate API
API -> Embeddings : embed(q)
activate Embeddings
Embeddings --> API : queryEmbedding
deactivate Embeddings
API -> Chroma : query(embedding, k)
activate Chroma
Chroma --> API : topK chunks + metadata
deactivate Chroma
API --> Employee : results[]
deactivate API

note right of Employee
Expert User follows the same flow
end note



newpage

title Seq 2: Review Suggestions (Approve/Reject)

actor "Expert User" as ExpertUser
participant "FastAPI API" as API
participant "SQLite Workflow DB" as DB

ExpertUser -> API : GET /workflow/suggestions/{id}
activate API
API -> DB : SELECT suggestion
activate DB
DB --> API : suggestion
deactivate DB
API --> ExpertUser : suggestion
deactivate API

alt Approve
	ExpertUser -> API : POST /workflow/suggestions/{id}/review {decision:approved}
	activate API
	API -> DB : INSERT review + UPDATE suggestion.status=approved
	activate DB
	DB --> API : ok
	deactivate DB
	API --> ExpertUser : status=approved
	deactivate API
else Reject
	ExpertUser -> API : POST /workflow/suggestions/{id}/review {decision:rejected}
	activate API
	API -> DB : INSERT review + UPDATE suggestion.status=rejected
	activate DB
	DB --> API : ok
	deactivate DB
	API --> ExpertUser : status=rejected
	deactivate API
end





newpage

title Seq 3: Upload Document + Generate Draft Suggestion

actor "Expert User" as ExpertUser
participant "FastAPI API" as API
participant "Document Sources\n(PDF / Email / Text)" as Docs
participant "Document Parser" as Parser
participant "Ollama LLM" as LLM
participant "SQLite Workflow DB" as DB

ExpertUser -> Docs : select document
activate Docs
Docs --> ExpertUser : raw file
deactivate Docs

ExpertUser -> API : POST /documents/upload (file)
activate API
API -> Parser : parse + normalize
activate Parser
Parser --> API : normalizedText
deactivate Parser
API -> LLM : generate KB draft (YAML + Markdown)
activate LLM
LLM --> API : suggestionDraft
deactivate LLM
API -> DB : INSERT uploads + normalized_documents + suggestions(status=draft)
activate DB
DB --> API : ok
deactivate DB
API --> ExpertUser : upload_id + suggestion_id
deactivate API




newpage

title Seq 4: Apply Approved Suggestion + Automatic Re-index

actor "Expert User" as ExpertUser
participant "FastAPI API" as API
participant "SQLite Workflow DB" as DB
participant "Raw KB (Markdown + YAML)" as KB
participant "KB Indexer" as Indexer
participant "Ollama Embeddings" as Embeddings
participant "Chroma Vector Store" as Chroma

ExpertUser -> API : POST /workflow/suggestions/{id}/apply
activate API
API -> DB : check suggestion.status == approved
activate DB
DB --> API : ok
deactivate DB
API -> KB : write .md file into databases/knowledge_base/raw/
activate KB
KB --> API : ok
deactivate KB
API -> DB : INSERT applied_changes + UPDATE suggestion.status=applied
activate DB
DB --> API : ok
deactivate DB
API --> ExpertUser : applied (reindex=scheduled)
deactivate API

... background task ...
Indexer -> KB : read all .md
activate KB
KB --> Indexer : docs
deactivate KB
Indexer -> Embeddings : embed(chunks)
activate Embeddings
Embeddings --> Indexer : embeddings
deactivate Embeddings
Indexer -> Chroma : upsert(chunks, metadata)
activate Chroma
Chroma --> Indexer : ok
deactivate Chroma


@enduml


