@startuml

' AI Agent + Process Knowledge Base — class diagram (Current MVP Implementation)

skinparam style strictuml
skinparam packageStyle rectangle
skinparam shadowing false
skinparam classAttributeIconSize 0

hide circle
hide empty members

' Actors
class "Expert User" as ExpertUser <<actor>>
class Employee <<actor>>

' FastAPI layer (routers)
class DocumentsRouter {
  +POST /documents/upload(file)
}
class WorkflowRouter {
  +GET /workflow/suggestions/{id}
  +POST /workflow/suggestions/{id}/review
  +POST /workflow/suggestions/{id}/apply
}
class VectorRouter {
  +POST /vector/index/kb
  +GET /vector/search(q,k)
}

' Workflow DB (SQLite)
class WorkflowDb <<database>> {
  +uploads
  +normalized_documents
  +suggestions
  +reviews
  +applied_changes
}

' Core processing
class DocumentParser {
  +parse_document(filename: str, bytes): str
}
class AgentService {
  +process_document(prompt: str, normalizedText: str): str
}

' KB storage (source of truth)
class "Raw Knowledge Base\n(Markdown + YAML)" as RawKb <<storage>>

' Indexing + search
class KbIndexer {
  +index_kb(): stats
}
class ChromaVectorStore <<vector-db>> {
  +upsert(...)
  +query(...)
}

' External services
class "Ollama LLM" as OllamaLlm <<external>>
class "Ollama Embeddings" as OllamaEmbeddings <<external>>

' Relationships
ExpertUser --> DocumentsRouter : uploads
DocumentsRouter --> DocumentParser : normalizes
DocumentsRouter --> AgentService : generates draft
DocumentsRouter --> WorkflowDb : persists workflow data
AgentService --> OllamaLlm : calls

ExpertUser --> WorkflowRouter : reviews/applies
WorkflowRouter --> WorkflowDb : reads/writes status
WorkflowRouter --> RawKb : writes .md
WorkflowRouter --> KbIndexer : schedules re-index

Employee --> VectorRouter : searches
VectorRouter --> OllamaEmbeddings : embed query
VectorRouter --> ChromaVectorStore : query

KbIndexer --> RawKb : reads .md
KbIndexer --> OllamaEmbeddings : embed chunks
KbIndexer --> ChromaVectorStore : upserts

@enduml
