@startuml

' Sequence Diagrams — AI Agent + Process Knowledge Base (As-Built)

skinparam style strictuml
skinparam shadowing false

title Seq 1: Search Knowledge (Vector Search)

actor "Employee / Expert User" as User
participant "FastAPI API" as API
participant "Ollama Embeddings" as Embeddings
participant "Chroma Vector Store" as Chroma
participant "KB Reader (Markdown)" as KbReader
participant "Ollama LLM" as LLM

User -> API : POST /agent/knowledge-chat
activate API
API -> Embeddings : embed(q)
activate Embeddings
Embeddings --> API : queryEmbedding
deactivate Embeddings
API -> Chroma : query(embedding, k)
activate Chroma
Chroma --> API : topK chunks + metadata
deactivate Chroma

alt vector results found
	API -> LLM : generate answer (with vector context)
	activate LLM
	LLM --> API : answer text
	deactivate LLM
else fallback
	API -> KbReader : lexical search(query)
	activate KbReader
	KbReader --> API : lexical docs
	deactivate KbReader
	API -> LLM : generate answer (with lexical context)
	activate LLM
	LLM --> API : answer text
	deactivate LLM
end

API --> User : answer + sources
deactivate API



newpage

title Seq 2: Review Suggestions (Approve/Reject, Auth Protected)

actor "Expert User" as ExpertUser
participant "FastAPI API" as API
participant "SQLite Workflow DB" as DB

ExpertUser -> API : POST /api/auth/login
activate API
API -> DB : validate user credentials
activate DB
DB --> API : access token
deactivate DB
API --> ExpertUser : bearer token
deactivate API

ExpertUser -> API : GET /workflow/suggestions/{id}
activate API
API -> DB : SELECT suggestion
activate DB
DB --> API : suggestion
deactivate DB
API --> ExpertUser : suggestion
deactivate API

alt Approve
	ExpertUser -> API : POST /workflow/suggestions/{id}/review {decision:approved, Authorization}
	activate API
	API -> DB : validate expert role from auth_sessions/users
	DB --> API : authorized
	API -> DB : INSERT review + UPDATE suggestion.status=approved
	activate DB
	DB --> API : ok
	deactivate DB
	API --> ExpertUser : status=approved
	deactivate API
else Reject
	ExpertUser -> API : POST /workflow/suggestions/{id}/review {decision:rejected, Authorization}
	activate API
	API -> DB : validate expert role from auth_sessions/users
	DB --> API : authorized
	API -> DB : INSERT review + UPDATE suggestion.status=rejected
	activate DB
	DB --> API : ok
	deactivate DB
	API --> ExpertUser : status=rejected
	deactivate API
end





newpage

title Seq 3: Upload Document + Async Draft Suggestion Generation

actor "Expert User" as ExpertUser
participant "FastAPI API" as API
participant "Document Sources\n(PDF / DOCX / TXT)" as Docs
participant "Document Parser" as Parser
participant "Ollama LLM" as LLM
participant "SQLite Workflow DB" as DB
participant "Background Worker" as Worker

ExpertUser -> Docs : select document
activate Docs
Docs --> ExpertUser : raw file
deactivate Docs

ExpertUser -> API : POST /documents/upload (file)
activate API
API -> Parser : parse + normalize
activate Parser
Parser --> API : normalizedText
deactivate Parser
API -> DB : INSERT uploads + normalized_documents + suggestions(status=draft, model=__processing__)
activate DB
DB --> API : ok
deactivate DB
API --> ExpertUser : upload_id + suggestion_id
deactivate API

... asynchronous background task ...
API -> Worker : schedule _generate_suggestion_async(suggestion_id)
activate Worker
Worker -> LLM : generate structured draft
activate LLM
LLM --> Worker : suggestionDraft
deactivate LLM
Worker -> DB : UPDATE suggestions(suggestion_json, model)
activate DB
DB --> Worker : ok
deactivate DB
deactivate Worker




newpage

title Seq 4: Apply Approved Suggestion + Automatic Re-index

actor "Expert User" as ExpertUser
participant "FastAPI API" as API
participant "SQLite Workflow DB" as DB
participant "Raw KB (Markdown + YAML)" as KB
participant "KB Indexer" as Indexer
participant "Ollama Embeddings" as Embeddings
participant "Chroma Vector Store" as Chroma
participant "Reindex Status" as Status

ExpertUser -> API : POST /workflow/suggestions/{id}/apply (Authorization)
activate API
API -> DB : validate expert role from auth_sessions/users
DB --> API : authorized
API -> DB : check suggestion.status == approved
activate DB
DB --> API : ok
deactivate DB
API -> KB : write .md file into databases/knowledge_base/raw/
activate KB
KB --> API : ok
deactivate KB
API -> DB : INSERT applied_changes + UPDATE suggestion.status=applied
activate DB
DB --> API : ok
deactivate DB
API -> Status : mark scheduled + run_id
API --> ExpertUser : applied (reindex=scheduled)
deactivate API

... background task ...
Indexer -> Status : mark in_progress
Indexer -> KB : read all .md
activate KB
KB --> Indexer : docs
deactivate KB
Indexer -> Embeddings : embed(chunks)
activate Embeddings
Embeddings --> Indexer : embeddings
deactivate Embeddings
Indexer -> Chroma : upsert(chunks, metadata)
activate Chroma
Chroma --> Indexer : ok
deactivate Chroma
Indexer -> Status : mark completed/failed (+stats)


@enduml


