@startuml
left to right direction
skinparam packageStyle rectangle

actor "Expert User" as Expert
actor "Employee" as Employee
actor "Language Model Service\n(Microsoft / OpenAI / Ollama)" as LLM
actor "Storage / Repository\n(Local / Git)" as Storage
actor "Document Sources\n(PDF / Email / Text)" as Docs

rectangle "AI Agent + Process Knowledge Base" {

  usecase "Login" as UC_Login
  usecase "Upload Documents" as UC_Upload
  usecase "Review Suggestions" as UC_Review
  usecase "Approve Changes" as UC_Approve
  usecase "Reject Suggestions" as UC_Reject
  usecase "Parse & Normalize" as UC_Parse
  usecase "Generate Update Suggestions" as UC_Generate
  usecase "Save Updates" as UC_Save
  usecase "Read Knowledge\n(HTML)" as UC_Read
  usecase "Report Issue / Feedback" as UC_Report

}

' Expert user interactions
Expert --> UC_Upload
Expert --> UC_Review
Expert --> UC_Approve
Expert --> UC_Parse
Expert --> UC_Generate
Expert --> UC_Save
Expert --> UC_Read

' Employee interactions
Employee --> UC_Read
Employee --> UC_Report

' External systems
Docs --> UC_Upload
LLM --> UC_Generate
Storage --> UC_Save

' Relationships
UC_Review ..> UC_Login : <<include>>
UC_Read ..> UC_Login : <<include>>
UC_Report ..> UC_Login : <<include>>

UC_Reject ..> UC_Review : <<extend>>


@enduml